# --- Casper Network ---
CASPER_NETWORK_NAME=casper-test
CASPER_NODE_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_NODE_SSE_URL=https://node.testnet.casper.network/events
CSPR_CLOUD_API_KEY=

# --- Wallets (paths to .pem files, never commit real keys) ---
