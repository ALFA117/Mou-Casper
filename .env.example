SERVICER_SECRET_KEY_PATH=./keys/servicer_secret_key.pem
SERVICER_PUBLIC_KEY_PATH=./keys/servicer_public_key.pem
UNDERWRITER_A_SECRET_KEY_PATH=./keys/underwriter_A_secret_key.pem
UNDERWRITER_A_PUBLIC_KEY_PATH=./keys/underwriter_A_public_key.pem
UNDERWRITER_B_SECRET_KEY_PATH=./keys/underwriter_B_secret_key.pem
UNDERWRITER_B_PUBLIC_KEY_PATH=./keys/underwriter_B_public_key.pem
INVESTOR_SECRET_KEY_PATH=./keys/investor_secret_key.pem
INVESTOR_PUBLIC_KEY_PATH=./keys/investor_public_key.pem

# --- Deployed contract hashes (fill in after deploy) ---
TRANCHE_VAULT_CONTRACT_HASH=
ATTESTATION_REGISTRY_CONTRACT_HASH=
UNDERWRITER_STAKE_CONTRACT_HASH=
REPUTATION_CONTRACT_HASH=
CONSTITUTION_CONTRACT_HASH=
